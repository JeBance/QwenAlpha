# Telegram Bot Token (обязательно)
# Получите у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Уровень логирования (debug, info, warn, error)
LOG_LEVEL=info

# Whitelist пользователей (опционально, через запятую)
# ALLOWED_USERS=123456789,987654321

# Таймаут Qwen в миллисекундах (по умолчанию 60000)
# QWEN_TIMEOUT=60000

# Максимальный размер буфера для Qwen (по умолчанию 10MB)
# QWEN_MAX_BUFFER=10485760

# Окно rate limiting в миллисекундах (по умолчанию 60000 = 1 минута)
# RATE_LIMIT_WINDOW=60000

# Максимум запросов на пользователя в окно rate limiting (по умолчанию 10)
# RATE_LIMIT_MAX=10
