# =============================================================================
# Qwen Alpha v2.0 — Конфигурация
# =============================================================================
# Скопируйте этот файл в .env и заполните значения
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot (обязательно)
# -----------------------------------------------------------------------------
# Получите токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
# Уровни: debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Безопасность
# -----------------------------------------------------------------------------
# Whitelist пользователей (опционально, через запятую)
# Если не указано — доступны все пользователи
# ALLOWED_USERS=123456789,987654321

# -----------------------------------------------------------------------------
# Qwen Code
# -----------------------------------------------------------------------------
# Таймаут выполнения команды Qwen (мс)
# По умолчанию: 300000 (5 минут)
# QWEN_TIMEOUT=300000

# Максимальный размер буфера для Qwen (байты)
# По умолчанию: 10485760 (10MB)
# QWEN_MAX_BUFFER=10485760

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Окно rate limiting (мс)
# По умолчанию: 60000 (1 минута)
# RATE_LIMIT_WINDOW=60000

# Максимум запросов на пользователя в окно rate limiting
# По умолчанию: 10
# RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# Сессии
# -----------------------------------------------------------------------------
# Срок жизни сессии (часы)
# По умолчанию: 24 часа
# SESSION_TIMEOUT_HOURS=24

# -----------------------------------------------------------------------------
# Web Search (для будущих версий)
# -----------------------------------------------------------------------------
# API-ключи для поиска в интернете (опционально)
# TAVILY_API_KEY=xxx
# GOOGLE_API_KEY=xxx
# GOOGLE_SEARCH_ENGINE_ID=xxx
